      <memberdef kind="function" id="hotcross_8h_1a2ca3478df49f013318abb7cf1b900163" prot="public" static="no" const="no" explicit="no" inline="no" virt="non-virtual">
        <type>__host__ __device__ double</type>
        <definition>__host__ __device__ double hc_klein_nishina</definition>
        <argsstring>(double we)</argsstring>
        <name>hc_klein_nishina</name>
        <param>
          <type>double</type>
          <declname>we</declname>
        </param>
        <briefdescription>
<para>Evaluates the normalized Klein-Nishina cross-section <formula id="13">$ \sigma_{KN} / \sigma_T $</formula>. </para>
        </briefdescription>
        <detaileddescription>
<para>Computes the total cross-section for a photon with dimensionless energy <formula id="2">$ w $</formula> in the electron rest frame. For <formula id="14">$ w &lt; 10^{-3} $</formula>, it uses the expansion <formula id="15">$ 1 - 2w $</formula>. Otherwise, it calculates: <formula id="16">\[ \sigma = \frac{3}{4} \left[ \frac{2}{w^2} + \left( \frac{1}{2w} - \frac{1+w}{w^3} \right) \ln(1+2w) + \frac{1+w}{(1+2w)^2} \right] \]</formula></para>
<para><parameterlist kind="param"><parameteritem>
<parameternamelist>
<parametername>we</parametername>
</parameternamelist>
<parameterdescription>
<para>Dimensionless photon frequency in the electron rest frame.</para>
</parameterdescription>
</parameteritem>
</parameterlist>
<simplesect kind="return"><para>The total cross-section normalized by the Thomson cross-section. </para>
</simplesect>
</para>
        </detaileddescription>
        <inbodydescription>
        </inbodydescription>

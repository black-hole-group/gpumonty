      <sectiondef kind="func">
      <memberdef kind="function" id="tetrads_8h_1ade72d9c30e6aa1a250be2050b34ed12a" prot="public" static="no" const="no" explicit="no" inline="no" virt="non-virtual">
        <type>__device__ void</type>
        <definition>__device__ void GPU_make_tetrad</definition>
        <argsstring>(double Ucon[NDIM], double trial[NDIM], const double Gcov[NDIM][NDIM], double Econ[NDIM][NDIM], double Ecov[NDIM][NDIM])</argsstring>
        <name>GPU_make_tetrad</name>
        <param>
          <type>double</type>
          <declname>Ucon</declname>
          <array>[NDIM]</array>
        </param>
        <param>
          <type>double</type>
          <declname>trial</declname>
          <array>[NDIM]</array>
        </param>
        <param>
          <type>const double</type>
          <declname>Gcov</declname>
          <array>[NDIM][NDIM]</array>
        </param>
        <param>
          <type>double</type>
          <declname>Econ</declname>
          <array>[NDIM][NDIM]</array>
        </param>
        <param>
          <type>double</type>
          <declname>Ecov</declname>
          <array>[NDIM][NDIM]</array>
        </param>
        <briefdescription>
<para>Constructs an orthonormal tetrad (local laboratory frame) for a moving observer. </para>
        </briefdescription>
        <detaileddescription>
<para>A tetrad represents a local Minkowski frame $(e_{(0)}, e_{(1)}, e_{(2)}, e_{(3)})$ at a point in curved spacetime.</para>
<para><simplesect kind="note"><para>This function uses the <bold>Gram-Schmidt process</bold> to orthogonalize a set of coordinate basis vectors against the fluid&apos;s 4-velocity.</para>
</simplesect>
<parameterlist kind="param"><parameteritem>
<parameternamelist>
<parametername>Ucon</parametername>
</parameternamelist>
<parameterdescription>
<para>The contravariant 4-velocity of the fluid/observer ($u^\mu$). </para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>trial</parametername>
</parameternamelist>
<parameterdescription>
<para>A trial vector used to define the first spatial direction (usually radial). </para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>Gcov</parametername>
</parameternamelist>
<parameterdescription>
<para>The covariant metric tensor ($g_{\mu\nu}$). </para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>Econ</parametername>
</parameternamelist>
<parameterdescription>
<para>[Output] Contravariant tetrad $e^\mu_{(a)}$. First index (k) is the tetrad label, second (l) is the coordinate index. </para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>Ecov</parametername>
</parameternamelist>
<parameterdescription>
<para>[Output] Covariant tetrad $e_{(a)\mu}$.</para>
</parameterdescription>
</parameteritem>
</parameterlist>
<simplesect kind="return"><para>void </para>
</simplesect>
</para>
        </detaileddescription>
        <inbodydescription>
        </inbodydescription>

      <memberdef kind="function" id="tetrads_8h_1a8a0da4e24c190d57ec68a765a8a5de4a" prot="public" static="no" const="no" explicit="no" inline="no" virt="non-virtual">
        <type>__device__ void</type>
        <definition>__device__ void GPU_tetrad_to_coordinate</definition>
        <argsstring>(const double Econ[NDIM][NDIM], const double K_tetrad[NDIM], double K[NDIM])</argsstring>
        <name>GPU_tetrad_to_coordinate</name>
        <param>
          <type>const double</type>
          <declname>Econ</declname>
          <array>[NDIM][NDIM]</array>
        </param>
        <param>
          <type>const double</type>
          <declname>K_tetrad</declname>
          <array>[NDIM]</array>
        </param>
        <param>
          <type>double</type>
          <declname>K</declname>
          <array>[NDIM]</array>
        </param>
        <briefdescription>
<para>Transforms a vector from the local tetrad (fluid) frame to the global coordinate frame. </para>
        </briefdescription>
        <detaileddescription>
<para>This function performs a change of basis. Physical processes are calculated in the local orthonormal.</para>
<para>The transformation is defined by the sum: <formula id="229">$ K^\mu = \sum_{a=0}^{3} e^\mu_{(a)} K^{(a)} $</formula></para>
<para><parameterlist kind="param"><parameteritem>
<parameternamelist>
<parametername>Econ</parametername>
</parameternamelist>
<parameterdescription>
<para>The contravariant tetrad basis vectors <formula id="230">$ e^\mu_{(a)} $</formula>. </para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>K_tetrad</parametername>
</parameternamelist>
<parameterdescription>
<para>The components of the vector in the local frame <formula id="231">$ K^{(a)} $</formula>. </para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>K</parametername>
</parameternamelist>
<parameterdescription>
<para>[Output] The components of the vector in the coordinate frame <formula id="232">$ K^\mu $</formula>.</para>
</parameterdescription>
</parameteritem>
</parameterlist>
<simplesect kind="return"><para>void </para>
</simplesect>
</para>
        </detaileddescription>
        <inbodydescription>
        </inbodydescription>
        <location file="src/tetrads.h" line="41" column="17" declfile="src/tetrads.h" declline="41" declcolumn="17"/>
      </memberdef>
      <memberdef kind="function" id="tetrads_8h_1ab80dc45ae288a6dedb2e7286305dbe88" prot="public" static="no" const="no" explicit="no" inline="no" virt="non-virtual">
        <type>__device__ void</type>
        <definition>__device__ void GPU_coordinate_to_tetrad</definition>
        <argsstring>(const double Ecov[NDIM][NDIM], const double K[NDIM], double K_tetrad[NDIM])</argsstring>
        <name>GPU_coordinate_to_tetrad</name>
        <param>
          <type>const double</type>
          <declname>Ecov</declname>
          <array>[NDIM][NDIM]</array>
        </param>
        <param>
          <type>const double</type>
          <declname>K</declname>
          <array>[NDIM]</array>
        </param>
        <param>
          <type>double</type>
          <declname>K_tetrad</declname>
          <array>[NDIM]</array>
        </param>
        <briefdescription>
<para>Projects a global coordinate vector into the local orthonormal tetrad (fluid) frame. This is the inverse operation of <computeroutput>GPU_tetrad_to_coordinate</computeroutput>. It is used to &quot;measure&quot; global quantities from the perspective of a local observer moving with the fluid. </para>
        </briefdescription>
        <detaileddescription>
<para>The projection is defined by the inner product of the coordinate vector with the covariant tetrad basis: <formula id="233">$ K^{(a)} = e_{(a)\mu} K^\mu $</formula></para>
<para><parameterlist kind="param"><parameteritem>
<parameternamelist>
<parametername>Ecov</parametername>
</parameternamelist>
<parameterdescription>
<para>The covariant tetrad basis vectors <formula id="234">$ e_{(a)\mu} $</formula>. </para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>K</parametername>
</parameternamelist>
<parameterdescription>
<para>The components of the vector in the coordinate frame <formula id="232">$ K^\mu $</formula>. </para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>K_tetrad</parametername>
</parameternamelist>
<parameterdescription>
<para>[Output] The components of the vector in the local frame <formula id="231">$ K^{(a)} $</formula>.</para>
</parameterdescription>
</parameteritem>
</parameterlist>
<simplesect kind="return"><para>void </para>
</simplesect>
</para>
        </detaileddescription>
        <inbodydescription>
        </inbodydescription>
        <location file="src/tetrads.h" line="58" column="17" declfile="src/tetrads.h" declline="58" declcolumn="17"/>
      </memberdef>
      <memberdef kind="function" id="tetrads_8h_1a4d34ab270232c8dbeef9cec70155d363" prot="public" static="no" const="no" explicit="no" inline="no" virt="non-virtual">
        <type>__device__ double</type>
        <definition>__device__ double GPU_delta</definition>
        <argsstring>(int i, int j)</argsstring>
        <name>GPU_delta</name>
        <param>
          <type>int</type>
          <declname>i</declname>
        </param>
        <param>
          <type>int</type>
          <declname>j</declname>
        </param>
        <briefdescription>
<para>Implements the Kronecker delta function <formula id="235">$ \delta_{ij} $</formula>. </para>
        </briefdescription>
        <detaileddescription>
<para><parameterlist kind="param"><parameteritem>
<parameternamelist>
<parametername>i</parametername>
</parameternamelist>
<parameterdescription>
<para>Row or vector index. </para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>j</parametername>
</parameternamelist>
<parameterdescription>
<para>Column or reference index. </para>
</parameterdescription>
</parameteritem>
</parameterlist>
<simplesect kind="return"><para>1.0 if i == j, otherwise 0.0. </para>
</simplesect>
</para>
        </detaileddescription>
        <inbodydescription>
        </inbodydescription>
        <location file="src/tetrads.h" line="67" column="19" declfile="src/tetrads.h" declline="67" declcolumn="19"/>
      </memberdef>
      <memberdef kind="function" id="tetrads_8h_1a7b58a0bd4b68a32510f73d168a8fda4a" prot="public" static="no" const="no" explicit="no" inline="no" virt="non-virtual">
        <type>__device__ void</type>
        <definition>__device__ void GPU_normalize</definition>
        <argsstring>(double *vcon, const double Gcov[NDIM][NDIM])</argsstring>
        <name>GPU_normalize</name>
        <param>
          <type>double *</type>
          <declname>vcon</declname>
        </param>
        <param>
          <type>const double</type>
          <declname>Gcov</declname>
          <array>[NDIM][NDIM]</array>
        </param>
        <briefdescription>
<para>Normalizes a contravariant 4-vector to unit length in curved spacetime. </para>
        </briefdescription>
        <detaileddescription>
<para>It follows the expression in General Relativity:</para>
<para><formula id="236">$ V^\mu_{\rm norm} = \frac{V^\mu}{\sqrt{\sum^4_{\mu = 0} \sum^4_{\nu = 0} g_{\mu\nu} V^\mu V^\nu}} $</formula></para>
<para><parameterlist kind="param"><parameteritem>
<parameternamelist>
<parametername>vcon</parametername>
</parameternamelist>
<parameterdescription>
<para>The contravariant vector <formula id="237">$v^\mu$</formula> to be normalized (modified in-place). </para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>Gcov</parametername>
</parameternamelist>
<parameterdescription>
<para>The covariant metric tensor <formula id="238">$g_{\mu\nu}$</formula> at the vector&apos;s location.</para>
</parameterdescription>
</parameteritem>
</parameterlist>
<simplesect kind="return"><para>void </para>
</simplesect>
</para>
        </detaileddescription>
        <inbodydescription>
        </inbodydescription>
        <location file="src/tetrads.h" line="82" column="17" declfile="src/tetrads.h" declline="82" declcolumn="17"/>
      </memberdef>
      <memberdef kind="function" id="tetrads_8h_1aff0979a80c6542cf37407f6217103cce" prot="public" static="no" const="no" explicit="no" inline="no" virt="non-virtual">
        <type>__device__ void</type>
        <definition>__device__ void GPU_project_out</definition>
        <argsstring>(double *vcona, double *vconb, const double Gcov[NDIM][NDIM])</argsstring>
        <name>GPU_project_out</name>
        <param>
          <type>double *</type>
          <declname>vcona</declname>
        </param>
        <param>
          <type>double *</type>
          <declname>vconb</declname>
        </param>
        <param>
          <type>const double</type>
          <declname>Gcov</declname>
          <array>[NDIM][NDIM]</array>
        </param>
        <briefdescription>
<para>Projects one vector out of another to ensure orthogonality in curved spacetime. This is used during the Gram-Schmidt process. It modifies vector &apos;a&apos; such that it becomes perpendicular to vector &apos;b&apos;. This orthogonality is defined via the metric tensor: <formula id="239">$g_{\mu\nu} A^\mu B^\nu = 0$</formula>. </para>
        </briefdescription>
        <detaileddescription>
<para><parameterlist kind="param"><parameteritem>
<parameternamelist>
<parametername>vcona</parametername>
</parameternamelist>
<parameterdescription>
<para>The vector to be modified ( <formula id="240">$A^\mu$</formula>). After the call, it will be orthogonal to vconb. </para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>vconb</parametername>
</parameternamelist>
<parameterdescription>
<para>The reference vector ( <formula id="241">$B^\mu$</formula>) to project against. </para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>Gcov</parametername>
</parameternamelist>
<parameterdescription>
<para>The covariant metric tensor ( <formula id="238">$g_{\mu\nu}$</formula>).</para>
</parameterdescription>
</parameteritem>
</parameterlist>
<simplesect kind="return"><para>void </para>
</simplesect>
</para>
        </detaileddescription>
        <inbodydescription>
        </inbodydescription>
        <location file="src/tetrads.h" line="96" column="17" declfile="src/tetrads.h" declline="96" declcolumn="17"/>

      <memberdef kind="function" id="compton_8h_1a95628da4319e226d82f6ea553afea193" prot="public" static="no" const="no" explicit="no" inline="no" virt="non-virtual">
        <type>__device__ double</type>
        <definition>__device__ double GPU_sample_thomson</definition>
        <argsstring>(curandState *localState)</argsstring>
        <name>GPU_sample_thomson</name>
        <param>
          <type>curandState *</type>
          <declname>localState</declname>
        </param>
        <briefdescription>
<para>Samples the scattering angle cosine for Thomson scattering. </para>
        </briefdescription>
        <detaileddescription>
<para>Uses rejection sampling to pick the cosine of the scattering angle <formula id="8">$ \mu = \cos\theta $</formula> according to the Thomson differential cross-section distribution: <formula id="9">\[ \frac{dP}{d\mu} = \frac{3}{8}(1 + \mu^2) \]</formula></para>
<para><parameterlist kind="param"><parameteritem>
<parameternamelist>
<parametername>localState</parametername>
</parameternamelist>
<parameterdescription>
<para>Pointer to the curand RNG state for the current thread.</para>
</parameterdescription>
</parameteritem>
</parameterlist>
<simplesect kind="return"><para>The sampled cosine of the scattering angle <formula id="10">$ \mu $</formula>. </para>
</simplesect>
</para>
        </detaileddescription>
        <inbodydescription>
        </inbodydescription>
        <location file="src/compton.h" line="65" column="19" declfile="src/compton.h" declline="65" declcolumn="19"/>

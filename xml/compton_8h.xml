      <memberdef kind="function" id="compton_8h_1a23889b06f89c43496986015e13a60f2e" prot="public" static="no" const="no" explicit="no" inline="no" virt="non-virtual">
        <type>__device__ void</type>
        <definition>__device__ void GPU_boost</definition>
        <argsstring>(double v[4], double u[4], double vp[4])</argsstring>
        <name>GPU_boost</name>
        <param>
          <type>double</type>
          <declname>v</declname>
          <array>[4]</array>
        </param>
        <param>
          <type>double</type>
          <declname>u</declname>
          <array>[4]</array>
        </param>
        <param>
          <type>double</type>
          <declname>vp</declname>
          <array>[4]</array>
        </param>
        <briefdescription>
<para>Performs a general Lorentz boost into the frame of a given 4-velocity. </para>
        </briefdescription>
        <detaileddescription>
<para>Transforms a 4-vector <formula id="5">$ v $</formula> from the laboratory frame into the frame moving with 4-velocity <formula id="6">$ u $</formula>. The implementation uses the general Lorentz transformation matrix to handle boosts in arbitrary directions.</para>
<para><parameterlist kind="param"><parameteritem>
<parameternamelist>
<parametername>v</parametername>
</parameternamelist>
<parameterdescription>
<para>Input 4-vector in the laboratory frame. </para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>u</parametername>
</parameternamelist>
<parameterdescription>
<para>4-velocity of the frame to boost into (where <formula id="7">$ u^0 = \gamma $</formula>). </para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>vp</parametername>
</parameternamelist>
<parameterdescription>
<para>Resulting boosted 4-vector in the co-moving frame.</para>
</parameterdescription>
</parameteritem>
</parameterlist>
<simplesect kind="return"><para>void </para>
</simplesect>
</para>
        </detaileddescription>

      <memberdef kind="function" id="curand_8h_1a933acc3f6fe6da53c8ae10278078860e" prot="public" static="no" const="no" explicit="no" inline="no" virt="non-virtual">
        <type>__device__ double</type>
        <definition>__device__ double legacy_standard_gamma</definition>
        <argsstring>(double shape, curandState *localState)</argsstring>
        <name>legacy_standard_gamma</name>
        <param>
          <type>double</type>
          <declname>shape</declname>
        </param>
        <param>
          <type>curandState *</type>
          <declname>localState</declname>
        </param>
        <briefdescription>
<para>Samples a standard Gamma distribution ($\Gamma(\alpha, 1)$) using Marsaglia-Tsang (for <formula id="46">$ \alpha \geq 1 $</formula>) and an acceptance–rejection transformation to reduce the problem to the shape ≥ 1 case (for <formula id="47">$ \alpha &lt; 1 $</formula>). </para>
        </briefdescription>
        <detaileddescription>
<para><parameterlist kind="param"><parameteritem>
<parameternamelist>
<parametername>shape</parametername>
</parameternamelist>
<parameterdescription>
<para>Shape parameter ($\alpha$) of the distribution. </para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>localState</parametername>
</parameternamelist>
<parameterdescription>
<para>Pointer to the thread-local cuRAND state. </para>
</parameterdescription>
</parameteritem>
</parameterlist>
<simplesect kind="return"><para>A random value sampled from the Gamma distribution. </para>
</simplesect>
</para>
        </detaileddescription>
        <inbodydescription>
        </inbodydescription>

      <memberdef kind="function" id="curand_8h_1a5c742f9247534502f6c5e0df8182193d" prot="public" static="no" const="no" explicit="no" inline="no" virt="non-virtual">
        <type>__device__ void</type>
        <definition>__device__ void legacy_gauss</definition>
        <argsstring>(double *out1, double *out2, curandState *localState)</argsstring>
        <name>legacy_gauss</name>
        <param>
          <type>double *</type>
          <declname>out1</declname>
        </param>
        <param>
          <type>double *</type>
          <declname>out2</declname>
        </param>
        <param>
          <type>curandState *</type>
          <declname>localState</declname>
        </param>
        <briefdescription>
<para>Generates two independent standard normal variables ($\mu=0, \sigma=1$) using the Marsaglia polar method. This is a rejection-based variant of the Box-Muller transform that avoids trigonometric functions by sampling coordinates within a unit circle. </para>
        </briefdescription>
        <detaileddescription>
<para><simplesect kind="see"><para><ulink url="https://en.wikipedia.org/wiki/Marsaglia_polar_method">Marsaglia_polar_method</ulink></para>
</simplesect>
<parameterlist kind="param"><parameteritem>
<parameternamelist>
<parametername>out1</parametername>
<parametername>out2</parametername>
</parameternamelist>
<parameterdescription>
<para>Pointers to store the two independent Gaussian results. </para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>localState</parametername>
</parameternamelist>
<parameterdescription>
<para>Pointer to the thread-local cuRAND state. </para>
</parameterdescription>
</parameteritem>
</parameterlist>
</para>
        </detaileddescription>
        <inbodydescription>
        </inbodydescription>

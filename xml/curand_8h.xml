      <memberdef kind="function" id="curand_8h_1afb8b0c03e481e93523bc9caa7f44d619" prot="public" static="no" const="no" explicit="no" inline="no" virt="non-virtual">
        <type>__device__ double</type>
        <definition>__device__ double chi_square</definition>
        <argsstring>(int df, curandState *localState)</argsstring>
        <name>chi_square</name>
        <param>
          <type>int</type>
          <declname>df</declname>
        </param>
        <param>
          <type>curandState *</type>
          <declname>localState</declname>
        </param>
        <briefdescription>
<para>Samples a Chi-square distributed random variable for a given degree of freedom. Uses the transformation property where a Chi-square distribution with $k$ degrees of freedom is equivalent to a Gamma distribution scaled by 2: $\chi^2(k) \sim 2\Gamma(k/2, 1)$. χ </para>
        </briefdescription>
        <detaileddescription>
<para><simplesect kind="see"><para><ulink url="https://en.wikipedia.org/wiki/Chi-squared_distribution#Relation_to_other_distributions">Wikipedia article about χ-Γ relation</ulink></para>
</simplesect>
<parameterlist kind="param"><parameteritem>
<parameternamelist>
<parametername>df</parametername>
</parameternamelist>
<parameterdescription>
<para>Degrees of freedom ($k$). </para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>localState</parametername>
</parameternamelist>
<parameterdescription>
<para>Pointer to the thread-local cuRAND state.</para>
</parameterdescription>
</parameteritem>
</parameterlist>
<simplesect kind="return"><para>A random value sampled from the $\chi^2$ distribution. </para>
</simplesect>
</para>
        </detaileddescription>
        <inbodydescription>
        </inbodydescription>
        <location file="src/curand.h" line="45" column="19" declfile="src/curand.h" declline="45" declcolumn="19"/>

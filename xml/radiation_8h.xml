        <detaileddescription>
<para>This function determines the angle <formula id="210">$\theta$</formula> between the photon&apos;s propagation direction and the local magnetic field vector, as measured in the local fluid frame.</para>
<para><parameterlist kind="param"><parameteritem>
<parameternamelist>
<parametername>X</parametername>
</parameternamelist>
<parameterdescription>
<para>Photon 4-position. </para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>K</parametername>
</parameternamelist>
<parameterdescription>
<para>Photon 4-wavevector <formula id="193">$K^\mu$</formula>. </para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>Ucov</parametername>
</parameternamelist>
<parameterdescription>
<para>Covariant fluid 4-velocity <formula id="194">$U_\mu$</formula>. </para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>Bcov</parametername>
</parameternamelist>
<parameterdescription>
<para>Covariant magnetic field 4-vector <formula id="211">$B_\mu$</formula>. </para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>B</parametername>
</parameternamelist>

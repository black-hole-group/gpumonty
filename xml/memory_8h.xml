        <type>__host__ void</type>
        <definition>__host__ void create1DTextureObj</definition>
        <argsstring>(cudaTextureObject_t *texObj, double *ptr, cudaArray_t *cudaArray)</argsstring>
        <name>create1DTextureObj</name>

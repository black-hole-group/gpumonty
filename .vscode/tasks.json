{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build",
            "type": "shell",
            "command": "gcc",
            "args": [
                "-pg", "-g", "-Wall", "-O0", "-fopenmp",
                "-o", "${workspaceFolder}/build/grmonty",
                "src/grmonty.c",
                "src/compton.c",
                "src/init_geometry.c",
                "src/tetrads.c",
                "src/geodesics.c",
                "src/radiation.c",
                "src/jnu_mixed.c",
                "src/hotcross.c",
                "src/track_super_photon.c",
                "src/scatter_super_photon.c",
                "src/harm_model.c",
                "src/harm_utils.c",
                "src/hamr_model.c",
                "src/init_hamr_data2D.c",
                "${workspaceFolder}/src/GPU_grmonty.cu",
                "-lm", "-lgsl", "-lgslcblas",
                "-I", "C:\\Users\\pedro\\Desktop\\gsl-2.7.1\\include",
                "-L", "C:\\Users\\pedro\\Desktop\\gsl-2.7.1\\lib",
                "-lstdc++", "-lcudart", "-lcuda"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "reveal": "always"
            },
            "problemMatcher": {
                "owner": "cpp",
                "fileLocation": ["relative", "${workspaceFolder}/build"],
                "pattern": {
                    "regexp": "^(.*):(\\d+):(\\d+):\\s+(warning|error):\\s+(.*)$",
                    "file": 1,
                    "line": 2,
                    "column": 3,
                    "severity": 4,
                    "message": 5
                }
            }
        },
        {
            "label": "Clean",
            "type": "shell",
            "command": "rm",
            "args": ["-rf", "${workspaceFolder}/build"]
        }
    ]
}

ypeName":"datasetContact","multiple":true,"typeClass":"compound","value":[{"datasetContactName":{"typeName":"datasetContactName","multiple":false,"typeClass":"primitive","value":"Prather, Ben"},"datasetContactAffiliation":{"typeName":"datasetContactAffiliation","multiple":false,"typeClass":"primitive","value":"Harvard University"},"datasetContactEmail":{"typeName":"datasetContactEmail","multiple":false,"typeClass":"primitive","value":"bprather@fas.harvard.edu"}}]},{"typeName":"dsDescription","multiple":true,"typeClass":"compound","value":[{"dsDescriptionValue":{"typeName":"dsDescriptionValue","multiple":false,"typeClass":"primitive","value":"This is a snapshot from a global general-relativistic magnetohydrodynamic (GRMHD) simulation, which was used to test several codes in the Event Horizon Telescope Collaboration's polarized imaging code comparison project (see first related publication).  Polarized images of emission at 230GHz, as might be observed by the Event Horizon Telescope, were produced by several different methods and codebases; the methods broadly agreed, as computed in the paper and shown in its Figure 6."}}]},{"typeName":"subject","multiple":true,"typeClass":"controlledVocabulary","value":["Astronomy and Astrophysics"]},{"typeName":"publication","multiple":true,"typeClass":"compound","value":[{"publicationRelationType":{"typeName":"publicationRelationType","multiple":false,"typeClass":"controlledVocabulary","value":"IsReferencedBy"},"publicationCitation":{"typeName":"publicationCitation","multiple":false,"typeClass":"primitive","value":"Comparison of Polarized Radiative Transfer Codes Used by the EHT Collaboration. Ben S. Prather et al 2023 ApJ 950 35"},"publicationIDType":{"typeName":"publicationIDType","multiple":false,"typeClass":"controlledVocabulary","value":"doi"},"publicationIDNumber":{"typeName":"publicationIDNumber","multiple":false,"typeClass":"primitive","value":"10.3847/1538-4357/acc586"},"publicationURL":{"typeName":"publicationURL","multiple":false,"typeClass":"primitive","value":"https://iopscience.iop.org/article/10.3847/1538-4357/acc586/pdf"}},{"publicationRelationType":{"typeName":"publicationRelationType","multiple":false,"typeClass":"controlledVocabulary","value":"IsSupplementedBy"},"publicationCitation":{"typeName":"publicationCitation","multiple":false,"typeClass":"primitive","value":"Prather et al., (2021). iharm3D: Vectorized General Relativistic Magnetohydrodynamics. Journal of Open Source Software, 6(66), 3336"},"publicationIDType":{"typeName":"publicationIDType","multiple":false,"typeClass":"controlledVocabulary","value":"doi"},"publicationIDNumber":{"typeName":"publicationIDNumber","multiple":false,"typeClass":"primitive","value":"10.21105/joss.03336"},"publicationURL":{"typeName":"publicationURL","multiple":false,"typeClass":"primitive","value":"https://doi.org/10.21105/joss.03336"}},{"publicationRelationType":{"typeName":"publicationRelationType","multiple":false,"typeClass":"controlledVocabulary","value":"IsSupplementedBy"},"publicationCitation":{"typeName":"publicationCitation","multiple":false,"typeClass":"primitive","value":"PATOKA: Simulating Electromagnetic Observables of Black Hole Accretion. George N. Wong et al 2022 ApJS 259 64"},"publicationIDType":{"typeName":"publicationIDType","multiple":false,"typeClass":"controlledVocabulary","value":"doi"},"publicationIDNumber":{"typeName":"publicationIDNumber","multiple":false,"typeClass":"primitive","value":"10.3847/1538-4365/ac582e"},"publicationURL":{"typeName":"publicationURL","multiple":false,"typeClass":"primitive","value":"https://iopscience.iop.org/article/10.3847/1538-4365/ac582e"}}]},{"typeName":"notesText","multiple":false,"typeClass":"primitive","value":"Simulation was performed with iharm3d (https://github.com/AFD-Illinois/iharm3d) at 288x128x128 zones in r, th, phi directions using modified Kerr-Schild coordinates as in Gammie et al. (2003).  This snapshot is a slice at constant Kerr-Schild time coordinate, 4500 gravitational times into the simulation after starting from a Fishbone-Moncrief equilibrium solution with inner edge at 6 gravitational radii, pressure maximum at 12.  Further details of the code and initialization used are available in the related publications."},{"typeName":"depositor","multiple":false,"typeClass":"primitive","value":"Prather, Benjamin"},{"typeName":"dateOfDeposit","multiple":false,"typeClass":"primitive","value":"2025-10-09"}]}},"files":[{"label":"sample_dump_SANE_a+0.94_MKS_0900.h5","restricted":false,"version":1,"datasetVersionId":505755,"dataFile":{"id":12137142,"persistentId":"","filename":"sample_dump_SANE_a+0.94_MKS_0900.h5","contentType":"application/x-hdf","friendlyType":"Hierarchical Data Format","filesize":302010648,"storageIdentifier":"s3://dvn-cloud:199c9b45b6c-874a713c19a9","rootDataFileId":-1,"md5":"dc8cf9b45136cd9b28bdb8ed197cfd69","checksum":{"type":"MD5","value":"dc8cf9b45136cd9b28bdb8ed197cfd69"},"tabularData":false,"creationDate":"2025-10-09","publicationDate":"2025-10-09","lastUpdateTime":"2025-10-09T16:29:22Z","fileAccessRequest":true}}]}}}